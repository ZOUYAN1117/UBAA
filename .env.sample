# Client Configuration
# The full URL of the server API
API_ENDPOINT=http://localhost:5432

# Server Configuration
# The port the server listens on
SERVER_PORT=5432
# The host/interface the server binds to (0.0.0.0 for all interfaces)
SERVER_BIND_HOST=0.0.0.0

# Security
JWT_SECRET=your_jwt_secret_here

USE_VPN=false

# Redis connection URI.
# Note: The server reads REDIS_URI from the process environment (System.getenv),
# so you must export this variable in your runtime environment; changing this
# value in .env alone will not take effect.
REDIS_URI=redis://localhost:6379
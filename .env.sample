# 客户端配置
# 服务端 API 的完整 URL
API_ENDPOINT=https://ubaa.mofrp.top:2021

# 服务端配置
# 服务监听端口
SERVER_PORT=5432
# 服务绑定的主机/网卡（0.0.0.0 表示监听所有网卡）
SERVER_BIND_HOST=0.0.0.0

# 当客户端版本与服务端版本不一致时打开的下载页面。
UPDATE_DOWNLOAD_URL=https://github.com/BUAASubnet/UBAA/releases

# 安全配置
# 位于同一 Nginx 入口后的所有服务节点必须使用相同的 JWT 密钥。
JWT_SECRET=your_jwt_secret_here

USE_VPN=false

# 运行时实例标识与代理集成
# 为每个后端节点设置唯一值，便于日志检索与 Grafana 下钻分析。
INSTANCE_ID=ubaa-server-1
# 当服务部署在 Nginx 或其他反向代理后方时，请保持启用。
ENABLE_FORWARDED_HEADERS=true
# 同源 Nginx 部署可保持为空。
# 跨域开发时，请设置以逗号分隔的允许来源列表，例如：
# CORS_ALLOWED_ORIGINS=http://localhost:8080,https://app.example.com
# 仅在临时本地调试时使用 *。
CORS_ALLOWED_ORIGINS=

# 认证令牌/会话生命周期
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
SESSION_TTL_DAYS=7
PRELOGIN_TTL_MINUTES=5
# 已提交会话在其他节点复用时，从 Redis 刷新 Cookie Jar 的间隔。
SESSION_COOKIE_SYNC_INTERVAL_MS=5000

# 认证韧性调优
# 服务端可并发执行的全新登录流程最大数量。
LOGIN_MAX_CONCURRENCY=6
# 基于 Redis 的分布式锁配置，用于全新登录/预登录会话提升。
# 该值应至少比 AUTH_LOGIN_TIMEOUT_MS / AUTH_PRELOAD_TIMEOUT_MS 高 2 秒；
# 服务会在启动时校验。
AUTH_DISTRIBUTED_LOCK_TTL_MS=20000
AUTH_DISTRIBUTED_LOCK_WAIT_MS=5000
# 上游会话校验的超时预算（毫秒）
# （用于 /api/v1/auth/status 与已提交会话复用校验）。
AUTH_VALIDATION_TIMEOUT_MS=3000
# 认证预加载探测的超时预算（毫秒）。
AUTH_PRELOAD_TIMEOUT_MS=3000
# 单次全新登录尝试的总超时预算（毫秒）。
AUTH_LOGIN_TIMEOUT_MS=18000

# Redis 连接 URI。
# 服务端会优先从 .env 读取该值，读取不到时再回退到
# 同名进程环境变量。
REDIS_URI=redis://localhost:6379
# 在 /health/ready 中检查 Redis 时的就绪探针超时时间。
REDIS_HEALTH_TIMEOUT_MS=1000
